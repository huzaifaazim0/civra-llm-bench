# Voice pipeline stress configuration

# --- STT ---
PARAKEET_BASE=http://127.0.0.1:37283
PARAKEET_WS=ws://127.0.0.1:37283/v1/ws/stt
IFW_MODEL=openai/whisper-large-v3
IFW_DEVICE=cuda
IFW_FLASH=0
IFW_DEVICE_MOE=cpu

# --- LLM (vLLM) ---
VLLM_BASE=http://127.0.0.1:8000
LLM_SYSTEM=You are a concise helpful phone agent. Reply in 1-2 short spoken sentences.
LLM_MAX_TOKENS=64
LLM_TEMPERATURE=0.3
DISABLE_THINKING=1

# --- TTS ---
KOKORO_BASE=http://127.0.0.1:32432
KOKORO_WS=ws://127.0.0.1:32432/v1/ws/tts
KOKORO_VOICE=af_heart
MELO_LANGUAGE=EN
MELO_SPEAKER=EN-US
MELO_DEVICE=cuda
MELO_DEVICE_MOE=cpu
NEUTTS_BACKBONE=neuphonic/neutts-air-q4-gguf
NEUTTS_BACKBONE_DEVICE=gpu
NEUTTS_BACKBONE_DEVICE_MOE=cpu
NEUTTS_CODEC=neuphonic/neucodec-onnx-decoder
NEUTTS_CODEC_DEVICE=cpu
NEUTTS_REF_CODES=/root/.cvr/tts/neutts/samples/jo.pt
NEUTTS_REF_TEXT=/root/.cvr/tts/neutts/samples/jo.txt
NEUTTS_ROOT=/root/.cvr/tts/neutts

# --- Stress ---
SWEEP_START=1
SWEEP_MAX=16
SWEEP_STEP_FACTOR=2
# Voice e2e includes STT+LLM+TTS; colder than text-only TTFT budgets.
STOP_TTFA_MS=4000
STOP_ERROR_RATE=0.05
FIXTURES_DIR=/root/.cvr/llm_stress_test/voice_pipeline/fixtures
RESULTS_DIR=/root/.cvr/llm_stress_test/voice_pipeline/results

# Sibling roots
PARAKEET_REALTIME_ROOT=/root/.cvr/parakeet_realtime
KOKORO_REALTIME_ROOT=/root/.cvr/kokoro-tts-realtime
GPU_COMMANDS=/root/.cvr/llm_stress_test/gpu/commands.sh
IFW_ROOT=/root/.cvr/stt/insanely-fast-whisper
MELO_ROOT=/root/.cvr/tts/melotts
