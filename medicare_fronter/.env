# Medicare fronter stress / correctness harness
# Copy to .env or export before running ./commands.sh

# OpenAI-compatible server (GPU vLLM default)
BASE_URL=http://127.0.0.1:8000
# Leave empty to auto-detect from GET /v1/models
MODEL=

# Agent persona
AGENT_NAME=Sarah
DEPARTMENT=Medicare department

# Structured JSON enforcement: vllm | openai | prompt
STRUCTURED_MODE=vllm

# Generation
MAX_TOKENS=256
TEMPERATURE=0.1
CONTEXT_TURNS=3

# Correctness / stress SLOs
TTFT_MS=500
MIN_TPS=4
STOP_TTFT_MS=1500
STOP_MIN_TPS=4
MAX_ERROR_RATE=0.05

# stress_turns / stress_sessions
CONCURRENCY=10
REQUESTS=20
SESSIONS=10

# find_limit (session concurrency ramp)
SWEEP_START=1
SWEEP_MAX=100
SWEEP_STEP=5
SWEEP_WAVES=1
