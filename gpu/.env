# llm_stress_test configuration — edit this file, then restart vLLM if model/server flags change.
# Loaded automatically by ./commands.sh

# --- Model / server ---
# Active model (open, no HF_TOKEN needed):
# MoE: ~30B total / ~3B active — AWQ for ~20GB Ada.
MODEL_PATH=QuixiAI/Qwen3-30B-A3B-AWQ
SERVED_MODEL_NAME=QuixiAI/Qwen3-30B-A3B-AWQ
#
# Other models to try (uncomment one MODEL_PATH + matching SERVED_MODEL_NAME,
# then: ./commands.sh stop_vllm && ./commands.sh start_vllm_bg && ./commands.sh wait_vllm)
#
# --- Small / fast (~1–4B, bf16, leave VLLM_QUANTIZATION empty) ---
# MODEL_PATH=Qwen/Qwen2.5-1.5B-Instruct
# SERVED_MODEL_NAME=Qwen2.5-1.5B-Instruct
# MODEL_PATH=Qwen/Qwen2.5-3B-Instruct
# SERVED_MODEL_NAME=Qwen/Qwen2.5-3B-Instruct
# MODEL_PATH=Qwen/Qwen3-4B-Instruct-2507
# SERVED_MODEL_NAME=Qwen3-4B-Instruct-2507
# MODEL_PATH=microsoft/Phi-4-mini-instruct
# SERVED_MODEL_NAME=Phi-4-mini-instruct
# MODEL_PATH=microsoft/Phi-3.5-mini-instruct
# SERVED_MODEL_NAME=Phi-3.5-mini-instruct
#
# --- Mid (~7–8B on 20GB: prefer VLLM_QUANTIZATION=fp8) ---
# MODEL_PATH=Qwen/Qwen2.5-7B-Instruct
# SERVED_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
# MODEL_PATH=mistralai/Mistral-7B-Instruct-v0.3
# SERVED_MODEL_NAME=Mistral-7B-Instruct-v0.3
#
# --- Large (~14B on 20GB: VLLM_QUANTIZATION=fp8, keep MAX_MODEL_LEN modest) ---
# MODEL_PATH=Qwen/Qwen2.5-14B-Instruct
# SERVED_MODEL_NAME=Qwen/Qwen2.5-14B-Instruct
#
# --- Gated (set HF_TOKEN below; accept license on Hugging Face) ---
# MODEL_PATH=google/gemma-3-1b-it
# SERVED_MODEL_NAME=gemma-3-1b-it
# MODEL_PATH=google/gemma-3-4b-it
# SERVED_MODEL_NAME=gemma-3-4b-it
# MODEL_PATH=meta-llama/Llama-3.2-3B-Instruct
# SERVED_MODEL_NAME=Llama-3.2-3B-Instruct
# MODEL_PATH=meta-llama/Llama-3.1-8B-Instruct
# SERVED_MODEL_NAME=Llama-3.1-8B-Instruct
#   (8B: also set VLLM_QUANTIZATION=fp8 and MAX_MODEL_LEN=8192)
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
BASE_URL=http://127.0.0.1:8000

# Leave empty for bf16. AWQ for MoE/14B on ~20GB; fp8 for 7B/8B.
VLLM_QUANTIZATION=awq_marlin
DTYPE=float16
GPU_MEMORY_UTILIZATION=0.95
# MoE AWQ is tight on 20GB — keep context modest for KV.
MAX_MODEL_LEN=4096
# Must be >= highest concurrency you plan to stress (sweep goes up to SWEEP_MAX).
MAX_NUM_SEQS=128

# Optional: path to a venv that already has vLLM installed
# VLLM_VENV=/root/.cvr/gemma1bit/venv

# Gated models (Gemma/Llama) need a token:
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# --- Stress defaults ---
CONCURRENCY=20
REQUESTS=20
TTFT_MS=500
MIN_TPS=4
MAX_TOKENS=64
TEMPERATURE=0.2

# --- Find-limit sweep (stress_find_limit) ---
# Stop when TTFT p95 exceeds STOP_TTFT_MS or per-user min TPS drops below STOP_MIN_TPS
SWEEP_START=1
SWEEP_MAX=500
SWEEP_STEP=10
STOP_TTFT_MS=1500
STOP_MIN_TPS=4
# Extra requests per concurrency level: total = concurrency * SWEEP_WAVES
SWEEP_WAVES=1

# --- Sustained load (stress_sustained) ---
SUSTAINED_CONCURRENCY=40
SUSTAINED_WAVES=10
