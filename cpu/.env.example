# CPU (llama.cpp) stress test configuration — edit this file, then restart llama-server if model/server flags change.
# Loaded automatically by ./commands.sh

# --- Model (GGUF path or filename under models/) ---
# Default: small open Qwen GGUF (download with: ./commands.sh download_model)
MODEL_FILE=Qwen2.5-1.5B-Instruct-Q4_K_M.gguf
SERVED_MODEL_NAME=Qwen2.5-1.5B-Instruct-Q4_K_M
#
# Hugging Face repo + filename used by download_model:
HF_GGUF_REPO=Qwen/Qwen2.5-1.5B-Instruct-GGUF
HF_GGUF_FILE=qwen2.5-1.5b-instruct-q4_k_m.gguf
#
# --- Alternatives (uncomment MODEL_FILE + matching HF_* , then download_model + restart) ---
#
# Gemma-3-1B (gated — set HF_TOKEN; accept license on Hugging Face):
# MODEL_FILE=gemma-3-1b-it-Q4_K_M.gguf
# SERVED_MODEL_NAME=gemma-3-1b-it-Q4_K_M
# HF_GGUF_REPO=bartowski/google_gemma-3-1b-it-GGUF
# HF_GGUF_FILE=google_gemma-3-1b-it-Q4_K_M.gguf
#
# Qwen2.5-3B:
# MODEL_FILE=Qwen2.5-3B-Instruct-Q4_K_M.gguf
# SERVED_MODEL_NAME=Qwen2.5-3B-Instruct-Q4_K_M
# HF_GGUF_REPO=Qwen/Qwen2.5-3B-Instruct-GGUF
# HF_GGUF_FILE=qwen2.5-3b-instruct-q4_k_m.gguf
#
# Phi-3.5-mini:
# MODEL_FILE=Phi-3.5-mini-instruct-Q4_K_M.gguf
# SERVED_MODEL_NAME=Phi-3.5-mini-instruct-Q4_K_M
# HF_GGUF_REPO=bartowski/Phi-3.5-mini-instruct-GGUF
# HF_GGUF_FILE=Phi-3.5-mini-instruct-Q4_K_M.gguf

LLAMA_HOST=0.0.0.0
LLAMA_PORT=8010
BASE_URL=http://127.0.0.1:8010

# Threads: leave empty to use all logical cores (nproc)
LLAMA_THREADS=
LLAMA_THREADS_BATCH=
# Concurrent slots (each holds a ctx). Higher = more concurrent users, more RAM.
LLAMA_PARALLEL=8
# Per concurrent slot (total KV = LLAMA_CTX_SIZE * LLAMA_PARALLEL)
LLAMA_CTX_SIZE=4096
LLAMA_BATCH_SIZE=512
# Force CPU-only
LLAMA_N_GPU_LAYERS=0

# Optional: path to llama-server binary (default: cpu/bin/llama-server or PATH)
# LLAMA_SERVER=/path/to/llama-server

# Gated GGUF repos:
# HF_TOKEN=
# HUGGING_FACE_HUB_TOKEN=

# --- Stress defaults (CPU SLOs are looser than GPU) ---
CONCURRENCY=4
REQUESTS=4
TTFT_MS=2000
MIN_TPS=1
MAX_TOKENS=64
TEMPERATURE=0.2
STRUCTURED_MODE=openai

# --- Find-limit sweep ---
SWEEP_START=1
SWEEP_MAX=32
SWEEP_STEP=2
STOP_TTFT_MS=8000
STOP_MIN_TPS=1
SWEEP_WAVES=1

# --- Sustained load ---
SUSTAINED_CONCURRENCY=4
SUSTAINED_WAVES=10
