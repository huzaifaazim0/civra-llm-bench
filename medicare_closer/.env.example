# Medicare closer stress / correctness / interactive harness
# Copy to .env or export before running ./commands.sh

BASE_URL=http://127.0.0.1:8000
MODEL=

# Agent persona
AGENT_NAME=Alex
BROKER_NAME=Summit Senior Advisors
STATE_NAME=Texas
EFFECTIVE_DATE=January 1, 2026

# Structured JSON enforcement: vllm | openai | prompt
STRUCTURED_MODE=vllm
PROMPT_STYLE=auto

# Generation (closer needs more tokens/context than fronter)
MAX_TOKENS=512
TEMPERATURE=0.1
INTERACTIVE_TEMPERATURE=0.6
# Spoken reply is always LLM-streamed. SLO is TTFT of that reply (not total time).
INTERACTIVE_TARGET_TTFT_MS=555
INTERACTIVE_MAX_TOKENS=120
INTERACTIVE_CONTEXT_TURNS=6
USE_CONTROLLER=1
USE_LLM_UNDERSTAND=0
CONTEXT_TURNS=8

# Correctness / stress SLOs (looser than fronter — longer turns)
STOP_TTFT_MS=2500
STOP_MIN_TPS=3
MAX_ERROR_RATE=0.08

# stress_turns / stress_sessions (lower concurrency — long context)
CONCURRENCY=5
REQUESTS=10
SESSIONS=5

# find_limit
SWEEP_START=1
SWEEP_MAX=40
SWEEP_STEP=5
SWEEP_WAVES=1
